  "ai_agent_preferences": {
    "claude": {
      "use_for": [
        "complex_problem_solving",
        "ethical_reasoning",
        "long_form_writing",
        "research_synthesis",
        "framework_development"
      ],
      "avoid_for": [
        "quick_coding_tasks",
        "rapid_prototyping",
        "visual_design"
      ],
      "custom_instructions": "Focus on providing comprehensive, well-structured responses that support ADHD cognitive patterns. Use clear headings, bullet points, and practical examples. Break down complex concepts into manageable steps. Provide context and explain the 'why' behind recommendations. Be encouraging and supportive of different thinking patterns."
    },
    "chatgpt": {
      "use_for": [
        "quick_ideation",
        "rapid_prototyping",
        "technical_validation",
        "brainstorming",
        "quick_coding_snippets"
      ],
      "avoid_for": [
        "complex_ethical_dilemmas",
        "long_form_documentation",
        "framework_architecture"
      ],
      "custom_instructions": "Provide quick, focused responses that respect ADHD attention patterns. Use clear structure with headings and bullets. Give practical, actionable advice. Be concise but complete. Support interest-driven learning by connecting topics to user interests when possible."
    },
    "cursor": {
      "use_for": [
        "code_implementation",
        "repository_management",
        "technical_documentation",
        "debugging",
        "refactoring",
        "testing"
      ],
      "avoid_for": [
        "high_level_strategy",
        "business_decisions",
        "user_research"
      ],
      "custom_instructions": "Support ADHD development patterns with clear code organization, comprehensive comments, and external memory systems. Break down complex tasks into smaller, manageable steps. Provide progress tracking and completion indicators. Use descriptive naming and clear structure. Minimize cognitive load with automated repetitive tasks."
    },
    "gemini": {
      "use_for": [
        "visual_design",
        "ui_ux_mockups",
        "google_ecosystem_integration",
        "visual_documentation",
        "presentation_materials"
      ],
      "avoid_for": [
        "complex_coding",
        "ethical_reasoning",
        "research_validation"
      ],
      "custom_instructions": "Create visually organized, ADHD-friendly designs with clear structure and minimal clutter. Use visual hierarchy to guide attention. Provide multiple visual formats for different learning styles. Support external memory with clear visual organization."
    },
    "perplexity": {
      "use_for": [
        "real_time_research",
        "fact_checking",
        "market_intelligence",
        "current_events",
        "validation_of_claims"
      ],
      "avoid_for": [
        "creative_writing",
        "personal_advice",
        "complex_problem_solving"
      ],
      "custom_instructions": "Provide well-sourced, current information in a structured format that supports ADHD attention patterns. Use clear headings and bullet points. Cite sources clearly. Focus on accuracy and relevance. Present information in digestible chunks."
    }
  },
