{
  "name": "@neurolift-technologies/otoi",
  "version": "1.0.0",
  "description": "Reference implementation of the .otoi (Orchestrated Terms of Interaction) honoring layer — the multi-agent orchestration standard built on the canonical @neurolift-technologies/toi file type.",
  "keywords": [
    "otoi",
    "toi",
    "terms-of-interaction",
    "ai-governance",
    "multi-agent",
    "orchestration",
    "user-agency",
    "solidarity-framework"
  ],
  "license": "MIT",
  "author": "NeuroLift Technologies, LLC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@neurolift-technologies/toi": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
}
